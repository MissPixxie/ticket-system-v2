// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
}

enum AuditMessageType {
  USER_MESSAGE
  SYSTEM_MESSAGE
}

enum Severity {
  INFO
  WARNING
  ERROR
}

model AuditLog {
  id         String   @id @default(cuid())
  type       String
  severity   Severity
  entityType String
  entityId   String
  message    String
  diff       Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId String?

  @@index([entityId])
  @@index([actorId])
  @@index([createdAt])
}

enum EventType {
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  TICKET_ASSIGNED
  TICKET_CHANGED_PRIORITY
  MESSAGE_ADDED
  SUGGESTION_CREATED
  SUGGESTION_STATUS_CHANGED
  SUGGESTION_VOTED
  ROLE_CHANGED
  NEWS_CREATED
  NEWS_CHANGED
  NEWS_CHANGED_PRIORITY
  QUESTION_CREATED
  QUESTION_STATUS_CHANGED
  RESOURCE_CREATED
  RESOURCE_CHANGED
}

enum EventOrigin {
  TICKET
  SUGGESTION
  NEWS
  QUESTION
  RESOURCE
}

model Event {
  id         String      @id @default(cuid())
  type       EventType
  originId   String
  originType EventOrigin
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor         User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId       String?
  notifications Notification[]

  @@index([originId, originType])
  @@index([actorId])
  @@index([createdAt])
}

// SUGGESTION BOX MODELS
enum SuggestionStatus {
  SENT
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

model SuggestionBox {
  id          String       @id @default(cuid())
  suggestions Suggestion[]

  @@index([id])
}

model Suggestion {
  id          String           @id @default(cuid())
  content     String
  createdAt   DateTime         @default(now())
  status      SuggestionStatus @default(SENT)
  isAnonymous Boolean          @default(false)
  user        User?            @relation("SuggestionOwner", fields: [userId], references: [id], onDelete: SetNull)
  userId      String?

  suggestionBox   SuggestionBox @relation(fields: [suggestionBoxId], references: [id])
  suggestionBoxId String

  votes       Vote[]
  voteCount   Int            @default(0)
  subscribers Subscription[]

  @@index([status])
  @@index([suggestionBoxId])
  @@index([userId])
}

model Vote {
  id           String     @id @default(cuid())
  type         String
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id])
  suggestionId String

  @@unique([userId, suggestionId])
  @@index([suggestionId])
}

model Question {
  id          String   @id @default(cuid())
  question    String
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  thread      Thread?

  @@index([id])
  @@index([createdAt])
}

// MESSAGE ENUMS & MODEL

model Thread {
  id        String     @id @default(cuid())
  type      ParentType
  createdAt DateTime   @default(now())

  messages Message[]

  ticket   Ticket? @relation(fields: [ticketId], references: [id])
  ticketId String? @unique

  question   Question? @relation(fields: [questionId], references: [id])
  questionId String?   @unique

  @@unique([id])
  @@index([id])
  @@index([ticketId])
  @@index([questionId])
}

enum MessageType {
  USER_MESSAGE
  HANDLER_MESSAGE
  SYSTEM_MESSAGE
}

model Message {
  id        String      @id @default(cuid())
  message   String
  type      MessageType @default(USER_MESSAGE)
  createdAt DateTime    @default(now())

  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  thread   Thread? @relation(fields: [threadId], references: [id])
  threadId String?

  @@unique([id])
  @@index([threadId])
}

enum ParentType {
  TICKET
  QUESTION
}

enum SubscriptionType {
  TICKET
  SUGGESTION
  NEWS
  QUESTION
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String
  type      SubscriptionType
  originId  String
  createdAt DateTime         @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion   Suggestion? @relation(fields: [suggestionId], references: [id])
  suggestionId String?

  @@unique([userId, type, originId])
  @@index([originId, type])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])

  @@index([userId, seen])
  @@index([createdAt])
}

// NEWS & CAMPAIGN MODEL

model News {
  id          String       @id @default(cuid())
  title       String
  category    NewsCategory @default(NEWS)
  content     String
  createdBy   User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  priority    Priority @default(LOW)

  votes     NewsVote[]
  upVotes   Int           @default(0)
  downVotes Int           @default(0)
  comments  NewsComment[]

  @@index([isPublished])
}

enum NewsCategory {
  NEWS
  STORE_MANUAL
  PRODUCT_INFORMATION
  CAMPAIGN
}

model NewsVote {
  id        String   @id @default(cuid())
  type      VoteType
  userId    String
  newsId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([newsId])
}

enum VoteType {
  UP
  DOWN
}

model NewsComment {
  id        String   @id @default(cuid())
  content   String
  userId    String?
  newsId    String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  news News  @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@index([newsId])
}

