// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
}

enum EventType {
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  TICKET_ASSIGNED
  TICKET_CHANGED_PRIORITY
  MESSAGE_ADDED
  SUGGESTION_CREATED
  SUGGESTION_STATUS_CHANGED
}

enum EventOrigin {
  TICKET
  SUGGESTION
}

model Event {
  id         String      @id @default(cuid())
  type       EventType
  actorId    String
  originId   String
  originType EventOrigin
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor         User           @relation(fields: [actorId], references: [id])
  notifications Notification[]

  @@index([originId, originType])
  @@index([actorId])
  @@index([createdAt])
}

enum SubscriptionType {
  TICKET
  SUGGESTION
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String
  type      SubscriptionType
  originId  String
  createdAt DateTime         @default(now())

  user         User        @relation(fields: [userId], references: [id])
  suggestion   Suggestion? @relation(fields: [suggestionId], references: [id])
  suggestionId String?

  @@unique([userId, type, originId])
  @@index([originId, type])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@index([userId, seen])
  @@index([createdAt])
}

// SUGGESTION BOX MODELS
enum SuggestionStatus {
  SENT
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

model SuggestionBox {
  id          String       @id @default(cuid())
  suggestions Suggestion[]
}

model Suggestion {
  id          String           @id @default(cuid())
  content     String
  createdAt   DateTime         @default(now())
  status      SuggestionStatus @default(SENT)
  isAnonymous Boolean          @default(false)
  user        User             @relation("SuggestionOwner", fields: [userId], references: [id])
  userId      String

  suggestionBox   SuggestionBox @relation(fields: [suggestionBoxId], references: [id])
  suggestionBoxId String

  votes       Vote[]
  subscribers Subscription[]

  @@index([status])
}

model Vote {
  id           String     @id @default(cuid())
  type         String
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id])
  suggestionId String

  @@unique([userId, suggestionId])
}

// TICKET ENUMS & MODEL
enum Department {
  IT
  HR
  CAMPAIGN
  PRODUCT
  CUSTOMERCLUB
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String     @id @default(cuid())
  title       String
  issue       String
  image       String?
  isAnonymous Boolean    @default(false)
  department  Department
  status      Status     @default(OPEN)
  priority    Priority   @default(LOW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  solvedAt    DateTime?

  createdBy    User      @relation("TicketsCreated", fields: [createdById], references: [id])
  createdById  String
  assignedTo   User?     @relation("TicketsHandled", fields: [assignedToId], references: [id])
  assignedToId String?
  participants User[]    @relation("TicketParticipants")
  messages     Message[]

  @@unique([id])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([department])
}

// MESSAGE ENUMS & MODEL
enum MessageType {
  USER_MESSAGE
  HANDLER_MESSAGE
  SYSTEM_MESSAGE
}

model Message {
  id        String      @id @default(cuid())
  message   String
  type      MessageType @default(USER_MESSAGE)
  createdAt DateTime    @default(now())

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String

  @@unique([id])
  @@index([ticketId])
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

// USER & ROLES
model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
}

model Permission {
  id     String  @id @default(cuid())
  name   String
  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  @@unique([name])
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  password      String?
  emailVerified Boolean? @default(false)
  image         String?
  role          Role?    @relation(fields: [roleId], references: [id])
  roleId        String?
  // POSTGRES VERSION
  // departments Department[]

  // SQLITE VERSION
  departments    UserDepartment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt
  sessions       Session[]
  accounts       Account[]
  ticketsCreated Ticket[]         @relation("TicketsCreated")
  ticketsHandled Ticket[]         @relation("TicketsHandled")
  messages       Message[]
  posts          Post[]
  votes          Vote[]
  notifications  Notification[]

  events        Event[]
  subscriptions Subscription[]
  suggestionId  String?

  suggestions          Suggestion[] @relation("SuggestionOwner")
  ticketsParticipating Ticket[]     @relation("TicketParticipants")
}

model UserDepartment {
  id         String     @id @default(cuid())
  userId     String
  department Department

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, department])
}

// NEXT-AUTH MODELS
model Account {
  id                       String   @id @default(cuid())
  accountId                String   @unique
  userId                   String
  type                     String?
  provider                 String?
  providerId               String?
  password                 String?
  createdAt                DateTime
  updatedAt                DateTime
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@index([userId])
  @@index([accountId, providerId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@index([identifier])
}
